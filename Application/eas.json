{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GOOGLE_SERVICES_JSON": "file:GOOGLE_SERVICES_JSON",
        "EXPO_PUBLIC_SERVER_URL": "$EXPO_PUBLIC_SERVER_URL",
        "EXPO_PUBLIC_THIRDWEB_CLIENT_ID": "$EXPO_PUBLIC_THIRDWEB_CLIENT_ID",
        "EXPO_PUBLIC_THIRDWEB_SECRET_KEY": "$EXPO_PUBLIC_THIRDWEB_SECRET_KEY",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "$EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "$EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "$EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "GOOGLE_SERVICES_JSON": "file:GOOGLE_SERVICES_JSON",
        "EXPO_PUBLIC_SERVER_URL": "$EXPO_PUBLIC_SERVER_URL",
        "EXPO_PUBLIC_THIRDWEB_CLIENT_ID": "$EXPO_PUBLIC_THIRDWEB_CLIENT_ID",
        "EXPO_PUBLIC_THIRDWEB_SECRET_KEY": "$EXPO_PUBLIC_THIRDWEB_SECRET_KEY",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "$EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "$EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "$EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID"
      }
    }
  },
  "submit": {
    "production": {}
  }
}