# Email Configuration for OTP verification
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@chamapay.com
APP_URL=http://localhost:8082

# Existing JWT Secret
JWT_SECRET=your-jwt-secret-here

# Alchemy Webhook Configuration
ALCHEMY_WEBHOOK_SIGNING_KEY=your-alchemy-webhook-signing-key
ALCHEMY_API_KEY=your-alchemy-api-key
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Coinbase Developer Platform — EIP-7702 + Paymaster (Base mainnet)
# Portal -> Onchain Tools -> Paymaster -> Configuration
COINBASE_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/your-api-key

# CDP API credentials (Portal -> API Keys)
CDP_API_KEY_ID=your-api-key-id
CDP_API_KEY_SECRET=your-api-key-secret
CDP_WALLET_SECRET=your-wallet-secret
# Legacy alias supported by the server:
# WALLET_SECRET=your-wallet-secret
